# ---------------------------------------------------------------------------
# Repo Onboarding viewer — environment
# ---------------------------------------------------------------------------
# With NONE of these set, the app runs in LOCAL mode: filesystem fixtures from
# ../data, no auth, no database, no blob. Copy this file to `.env.local` and
# fill in every key to switch to CLOUD mode (auth + per-user storage + upload).
#
# Mode is auto-detected from the keys below; set APP_MODE to force one.
# ---------------------------------------------------------------------------

# Optional. "local" or "cloud". Leave unset to auto-detect from the keys below
# (cloud only when ALL of the four required keys are present).
# APP_MODE=cloud

# --- Clerk (authentication) ------------------------------------------------
# Provision via the Vercel Marketplace (Clerk) or clerk.com. Keys live in the
# Clerk dashboard under "API Keys".
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=<your-clerk-publishable-key>
CLERK_SECRET_KEY=<your-clerk-secret-key>

# Optional Clerk URL overrides. Defaults use Clerk's hosted account portal, so
# these are only needed if you host your own sign-in/sign-up routes.
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
# NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# --- Neon Postgres (metadata) ----------------------------------------------
# Provision via the Vercel Marketplace (Neon) — the integration sets this
# automatically on Vercel. For local dev, copy the connection string from the
# Neon dashboard. Use the pooled/serverless URL.
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# --- Vercel Blob (analysis.json payloads, private) -------------------------
# Provision via the Vercel dashboard → Storage → Blob. The token is created
# with the store; on Vercel it is injected automatically.
BLOB_READ_WRITE_TOKEN=<your-vercel-blob-read-write-token>

# --- "Ask this repo" chat (optional; works in BOTH local and cloud mode) ---
# Chat is enabled iff this key is set. Create in the Vercel dashboard under
# AI Gateway -> API Keys. Uses the recurring $5/month free credit; NEVER
# purchase credits (a purchase permanently ends the recurring free credit).
# AI_GATEWAY_API_KEY=
# Gateway model id ("provider/model"). Default: google/gemini-3-flash
# CHAT_MODEL=
# Per-user daily message cap, cloud mode only. Default: 30
# CHAT_DAILY_MESSAGE_LIMIT=
# Optional GitHub token: raises rate limits for the chat's file-fetch tool
# GITHUB_TOKEN=
