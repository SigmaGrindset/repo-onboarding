{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:local": "cross-env APP_MODE=local NEXT_DIST_DIR=.next-local next build",
    "start": "next start",
    "start:local": "cross-env APP_MODE=local NEXT_DIST_DIR=.next-local next start -p 3100",
    "lint": "eslint",
    "test": "npm run test:unit && npm run test:ui",
    "test:unit": "tsx --test src/lib/__tests__/*.test.ts",
    "test:ui": "vitest run",
    "test:e2e": "npm run build:local && playwright test",
    "test:e2e:update": "npm run build:local && playwright test visual.spec.ts --update-snapshots"
  },
  "dependencies": {
    "@ai-sdk/react": "^4.0.23",
    "@clerk/nextjs": "^7.5.17",
    "@neondatabase/serverless": "^1.1.0",
    "@vercel/blob": "^2.6.1",
    "ai": "^7.0.22",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "d3-force": "^3.0.0",
    "drizzle-orm": "^0.45.2",
    "mermaid": "^11.16.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "streamdown": "^2.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3-force": "^3.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
